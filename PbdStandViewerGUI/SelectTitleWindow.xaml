<Window x:Class="PbdStandViewerGUI.SelectTitleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:local="clr-namespace:PbdStandViewerGUI"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=local:SelectTitleWindowViewModel}"
        Title="选择游戏" Height="360" Width="640" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Closed">
            <i:InvokeCommandAction Command="{Binding OnWindowClosed}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Window}}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid Margin="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!--游戏选择-->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="游戏" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="4"/>
        <ComboBox Grid.Row="0" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                  IsReadOnly="True" IsEditable="False" Margin="4" VerticalContentAlignment="Center"
                  ItemsSource="{Binding Mode=OneWay, Path=Titles}" 
                  SelectedIndex="{Binding Mode=TwoWay, Path=SelectIndex}">
        </ComboBox>
        
        <!--游戏参数-->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="参数" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="4"/>
        <TextBox Grid.Row="1" Grid.Column="1" Margin="4" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                 BorderBrush="Gray" BorderThickness="1"
                 IsReadOnly="True" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                 Text="{Binding Mode=OneWay, Path=Params}">
        </TextBox>

        <!--确认选择-->
        <Button Grid.Row="2" Grid.Column="1" Width="120" HorizontalAlignment="Right" VerticalAlignment="Stretch"
                Margin="4"
                Command="{Binding OnConfirmClick}" 
                CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Window}}">
            <TextBlock HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Text="确定"/>
        </Button>

    </Grid>
</Window>
